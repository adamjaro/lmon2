
<main>

  <!-- QCal2 production module -->

  <const name="qcal_mody" value="170"/> <!-- mm -->
  <const name="qcal_cell_xy" value="15"/> <!-- mm -->

  <const name="qcal_cell_phi" value="45"/> <!-- deg   45 -->

  <const name="qcal_cell_phi_rad" value="qcal_cell_phi*TMath::DegToRad()"/>
  <const name="qcal_cell_z" value="(qcal_mody-qcal_cell_xy*TMath::Sin(qcal_cell_phi_rad))/TMath::Cos(qcal_cell_phi_rad)"/>

  <!-- <const name="test_cy" value="qcal_cell_xy*TMath::Sin(qcal_cell_phi_rad)+qcal_cell_z*TMath::Cos(qcal_cell_phi_rad)"/> -->

  <const name="qcal_nz" value="16"/> <!-- number of cells along z -->
  <const name="qcal_nx" value="11"/> <!-- number of cells along x -->

  <!-- module length along z -->
  <const name="qcal_modz" value="qcal_cell_xy*(TMath::Cos(qcal_cell_phi_rad)+(qcal_nz-1)/TMath::Cos(qcal_cell_phi_rad))+qcal_cell_z*TMath::Sin(qcal_cell_phi_rad)"/>

  <!-- module length along x -->
  <const name="qcal_modx" value="qcal_cell_xy*qcal_nx"/>

  <detector
    type="QCal2" name="qcal"
    modx="qcal_modx" mody="qcal_mody" modz="qcal_modz"
    zpos="-0.5*qcal_modz" cell_phi="qcal_cell_phi"
    nz="qcal_nz" nx="qcal_nx"
    cell_xy="qcal_cell_xy" cell_z="qcal_cell_z"
    cell_mat_name="QCal2_Copper"
    fiber_clad_D="1.54" fiber_core_D="1.5" fiber_dx="4"
  >
  </detector>

  <!-- top volume -->
  <detector
    name="topv" type="top"
    xsiz = "500" ysiz="500" zsiz = "10000"> <!-- mm -->
  </detector>

</main>

