
<main>

  <!-- QCal2Fibers production geometry for fiber diameter 1 mm, no cladding, spacing 10 mm, SiPM 3 mm -->

  <const name="qcal_mody" value="530"/> <!-- mm, 25 mm added for lguide -->
  <const name="qcal_cell_xy" value="31"/> <!-- mm -->

  <const name="qcal_lguide_z" value="80"/> <!-- mm -->

  <const name="qcal_cell_phi" value="45"/> <!-- deg   45 -->

  <const name="qcal_nz" value="20"/> <!-- number of cells along z -->
  <const name="qcal_nx" value="15"/> <!-- number of cells along x -->

  <const name="qcal_cell_phi_rad" value="qcal_cell_phi*TMath::DegToRad()"/>
  <const name="qcal_cell_z" value="(qcal_mody-qcal_cell_xy*TMath::Sin(qcal_cell_phi_rad))/TMath::Cos(qcal_cell_phi_rad)"/>

  <!-- vertical position (mm), correction for lightguide -->
  <const name="qcal_ypos" value="0.5*qcal_mody-0.5*((qcal_cell_z-qcal_lguide_z)*TMath::Sin(qcal_cell_phi_rad))"/>

  <!-- module length along z -->
  <const name="qcal_modz" value="qcal_cell_xy*(TMath::Cos(qcal_cell_phi_rad)+(qcal_nz-1)/TMath::Cos(qcal_cell_phi_rad))+qcal_cell_z*TMath::Sin(qcal_cell_phi_rad)"/>

  <!-- module length along x -->
  <const name="qcal_modx" value="qcal_cell_xy*qcal_nx"/>

  <detector
    type="QCal2Fibers" name="qcal"
    modx="qcal_modx" mody="qcal_mody" modz="qcal_modz" mod_vis="0:0:1:2"
    zpos="-0.5*qcal_modz" ypos="qcal_ypos" cell_phi="qcal_cell_phi"
    nz="qcal_nz" nx="qcal_nx"
    cell_xy="qcal_cell_xy" cell_z="qcal_cell_z"
    abso_mat_name="G4_Pb"
    fiber_clad_D="-1" fiber_core_D="1"
    opdet_dxy="3" opdet_dz="0.2"
    fiber_dx="10" lguide_z="qcal_lguide_z"
    fibYZ_vis="0:1:1:1" core_vis="0:1:1:1"
    cell_vis="1:0:0:2" abso_vis="1:0:0:1"
    fiber_abso_delt="0.1" fib_lguide_dsmin="0.1"
    set_air_rindex_table="1"
    set_max_optical_en="4.96"
    set_min_optical_en="1.23"
  >
  </detector>

  <!-- fib_lguide_dsmin="0.1"  0.4 -->
  <!-- set_max_optical_en="4" -->

  <!-- top volume -->
  <detector
    name="topv" type="top"
    xsiz = "500" ysiz="500" zsiz = "10000"> <!-- mm -->
  </detector>

</main>

